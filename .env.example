# Binance
LATPOLY_BINANCE_WS=wss://stream.binance.com:9443/stream
LATPOLY_SYMBOL=BTCUSDT

# Polymarket
LATPOLY_POLY_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market
LATPOLY_POLY_REST=https://clob.polymarket.com
LATPOLY_GAMMA_API=https://gamma-api.polymarket.com

# Workers
LATPOLY_SIGNAL_INTERVAL=0.2
LATPOLY_QUEUE_SIZE=500
LATPOLY_DISCOVERY_LEAD=60

# Writer
LATPOLY_WRITER_BATCH=50
LATPOLY_WRITER_TIMEOUT=1.0
LATPOLY_DATA_DIR=./data

# Health
LATPOLY_HEALTH_INTERVAL=10

# Logging
LATPOLY_LOG_LEVEL=INFO
